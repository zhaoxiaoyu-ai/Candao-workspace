{
  "name": "xd-to-figma-converter",
  "version": "0.1.0",
  "private": true,
  "description": "CLI tool for converting Adobe XD files into Figma-ready design data.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test tests/**/*.test.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
